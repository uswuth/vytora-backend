{
	"info": {
		"name": "VRMP API - Full Workflow Test",
		"description": "Complete Postman collection for VRMP backend.\n\n## How to Use\n1. Import into Postman (File → Import)\n2. Set `base_url` variable (default: `http://localhost:8080`)\n3. Run **1. Auth → Login** first — token auto-saves\n4. Run folders **in order** — each folder builds on the previous one\n5. Each request has `Authorization: Bearer {{token}}` set explicitly\n\n## Prerequisites\n- `go run cmd/server/main.go`\n- `go run cmd/seed/main.go` (creates: admin@vrmp.com / admin123)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		},
		{
			"key": "user_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "vendor_code",
			"value": "",
			"type": "string"
		},
		{
			"key": "risk_code",
			"value": "",
			"type": "string"
		},
		{
			"key": "compliance_code",
			"value": "",
			"type": "string"
		},
		{
			"key": "contract_code",
			"value": "",
			"type": "string"
		},
		{
			"key": "category_code",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "0. Health",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["{{base_url}}"],
							"path": ["health"]
						}
					}
				}
			]
		},
		{
			"name": "1. Auth",
			"item": [
				{
					"name": "Login - System Admin",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Clear old variables to avoid stale/conflicting data",
									"pm.collectionVariables.unset(\"token\");",
									"pm.collectionVariables.unset(\"user_id\");",
									"pm.collectionVariables.unset(\"vendor_code\");",
									"pm.collectionVariables.unset(\"risk_code\");",
									"pm.collectionVariables.unset(\"compliance_code\");",
									"pm.collectionVariables.unset(\"contract_code\");",
									"pm.collectionVariables.unset(\"category_code\");"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Login successful - status 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"var jsonData = pm.response.json();",
									"pm.test(\"Token received\", function () {",
									"    pm.expect(jsonData.token).to.not.be.empty;",
									"});",
									"",
									"pm.collectionVariables.set(\"token\", jsonData.token);"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@vrmp.com\",\n  \"password\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/login",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "login"]
						}
					}
				},
				{
					"name": "Get Current User (Me)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Get current user successful - status 200\", function () {",
									"    pm.response.to.have.status(200);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.email).to.eql(\"admin@vrmp.com\");",
									"    pm.collectionVariables.set(\"user_id\", jsonData.user_id);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/me",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "me"]
						}
					}
				}
			]
		},
